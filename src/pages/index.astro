---
import Layout from '../layouts/Layout.astro';

const projects = [
	{
		title: 'ICE Breaker',
		description:
			'A cyberpunk tower-defense game built from scratch with vanilla TypeScript and the Canvas API — installable as a PWA, playable on desktop and mobile.',
		link: 'https://ssvito.github.io/ice-breaker/',
		repo: 'https://github.com/ssvito/ice-breaker',
		tags: ['TypeScript', 'Canvas API', 'PWA'],
	},
	{
		title: 'Project Two',
		description: 'TODO: replace with a real project once you have one to show.',
		link: 'https://github.com/ssvito',
		tags: ['TODO'],
	},
	{
		title: 'Project Three',
		description: 'TODO: replace with a real project once you have one to show.',
		link: 'https://github.com/ssvito',
		tags: ['TODO'],
	},
];
---

<Layout title="ssvito">
	<main>
		<section id="hero" style="margin-top: 0;">
			<h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">ssvito</h1>
			<p style="color: var(--muted); font-size: 1.15rem; margin: 0;">
				Software developer focused on web development.
			</p>
		</section>

		<section id="about">
			<h2>About</h2>
			<p>
				I'm a software developer with a focus on web development. This site is
				itself one of my projects — built with Astro and deployed on GitHub
				Pages. I'm currently building out my portfolio as I take on new projects,
				so check back for updates.
			</p>
		</section>

		<section id="projects">
			<h2>Projects</h2>
			<div style="display: grid; gap: 1.25rem;">
				{
					projects.map((project) => (
						<div style="padding: 1.25rem; background: var(--card); border: 1px solid var(--border); border-radius: 8px;">
							<h3 style="margin: 0 0 0.4rem;">
								<a href={project.link} style="color: var(--fg); text-decoration: none;">
									{project.title}
								</a>
							</h3>
							<p style="margin: 0 0 0.6rem; color: var(--muted);">{project.description}</p>
							{project.repo && (
								<a href={project.repo} style="font-size: 0.9rem;">
									Source →
								</a>
							)}
						</div>
					))
				}
			</div>
		</section>

		<section id="contact">
			<h2>Contact</h2>
			<p>
				<a href="https://github.com/ssvito">GitHub</a>
				&nbsp;·&nbsp;
				<a href="mailto:vitor.marcolin.ads@gmail.com">Email</a>
			</p>
		</section>
	</main>
</Layout>
